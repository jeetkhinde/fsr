diff --git a/examples/address-book/tests/fsr-dx.test.tsx b/examples/address-book/tests/fsr-dx.test.tsx
new file mode 100644
index 0000000..1d2d540
--- /dev/null
+++ b/examples/address-book/tests/fsr-dx.test.tsx
@@ -0,0 +1,102 @@
+import { describe, expect, it } from "bun:test";
+import {
+  bakeFragment,
+  createBakedSnapshot,
+  createImmutableShell,
+  materializeBakedShell,
+} from "@kiln/engine";
+import { ContactDetail } from "../components/ContactDetail.js";
+import { Directory } from "../components/Directory.js";
+import {
+  toContactView,
+  toDirectoryContacts,
+} from "../db/presentation.js";
+import type { Contact } from "../db/types.js";
+import ContactPage from "../pages/contacts/[id]/index.js";
+
+const ada: Contact = {
+  id: "42",
+  firstName: "Ada",
+  lastName: "Lovelace",
+  company: "Analytical Engines",
+  role: "Programmer",
+  email: "ada@example.com",
+  phone: "+44 20 7946 0958",
+  location: "London",
+  handle: "@ada",
+  website: "https://example.com/ada",
+  avatarUrl: "https://images.example.com/ada.jpg",
+  notes: "Writes programs for engines.",
+  favorite: true,
+  createdAt: "2026-01-01T00:00:00.000Z",
+  updatedAt: "2026-01-01T00:00:00.000Z",
+};
+
+describe("address book FSR authoring contract", () => {
+  it("authors the directory as an immutable keyed collection shell", async () => {
+    const contacts = toDirectoryContacts([ada]);
+    const rendered = await bakeFragment(Directory, {
+      contacts,
+      query: "Ada",
+    });
+    const shell = createImmutableShell(rendered);
+
+    expect(shell).toContain('data-kiln-list="contacts"');
+    expect(shell).toContain('data-kiln-live="/contacts"');
+    expect(shell).toContain('template data-kiln-each="contacts"');
+    expect(shell).toContain('data-kiln-key="id"');
+    expect(shell).toContain('data-kiln-text="contact.name"');
+    expect(shell).toContain(
+      'data-kiln-attr-data-search="contact.searchText"',
+    );
+    expect(shell).not.toContain("Ada Lovelace");
+
+    const materialized = materializeBakedShell(
+      shell,
+      createBakedSnapshot({ contacts, query: "Ada" }),
+    );
+    expect(materialized).toContain('data-kiln-key="42"');
+    expect(materialized).toContain("Ada Lovelace");
+    expect(materialized).toContain('href="/contacts/42"');
+  });
+
+  it("authors contact details as scalar and attribute bindings", async () => {
+    const contact = toContactView(ada);
+    const rendered = await bakeFragment(ContactDetail, { contact });
+    const shell = createImmutableShell(rendered);
+
+    expect(shell).toContain('data-kiln-text="contact.name"');
+    expect(shell).toContain('data-kiln-attr-href="contact.editHref"');
+    expect(shell).toContain(
+      'data-kiln-attr-aria-pressed="contact.favorite"',
+    );
+    expect(shell).not.toContain("Ada Lovelace");
+
+    const materialized = materializeBakedShell(
+      shell,
+      createBakedSnapshot({ contact }),
+    );
+    expect(materialized).toContain("Ada Lovelace");
+    expect(materialized).toContain('href="/contacts/42/edit"');
+    expect(materialized).toContain("aria-pressed");
+    expect(materialized).toContain(
+      'src="https://images.example.com/ada.jpg"',
+    );
+    expect(materialized).not.toContain("/ src=");
+  });
+
+  it("keeps the dynamic contact route shell identical for found and missing rows", async () => {
+    const foundShell = createImmutableShell(
+      await bakeFragment(ContactPage, { contact: toContactView(ada) }),
+    );
+    const missingShell = createImmutableShell(
+      await bakeFragment(ContactPage, { contact: toContactView(null) }),
+    );
+
+    expect(foundShell).toBe(missingShell);
+    expect(foundShell).toContain('data-kiln-attr-hidden="contact.hidden"');
+    expect(foundShell).toContain(
+      'data-kiln-attr-hidden="contact.missingHidden"',
+    );
+  });
+});
