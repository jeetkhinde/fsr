+function getAvatarStyle(id: string): string {
+  const hue = id ? Number((BigInt(id) * 47n) % 360n) : 0;
+  return `--avatar-hue: ${hue}`;
+}
+
+export function toDirectoryContacts(
+  contacts: ContactSummary[],
+): DirectoryContact[] {
+  let previousFavorite: boolean | undefined;
+
+  return contacts.map((contact) => {
+    const sectionHidden = previousFavorite === contact.favorite;
+    previousFavorite = contact.favorite;
+    const name = getContactName(contact);
+
+    return {
+      ...contact,
+      name,
+      subtitle: [contact.role, contact.company].filter(Boolean).join(" · "),
+      searchText: getContactSearchText(contact),
+      href: `/contacts/${contact.id}`,
+      initials: getContactInitials(contact),
+      avatarStyle: getAvatarStyle(contact.id),
+      avatarAlt: `${name} portrait`,
+      avatarHidden: !contact.avatarUrl,
+      favoriteHidden: !contact.favorite,
+      section: contact.favorite ? "favorites" : "all",
+      sectionLabel: contact.favorite ? "Favorites" : "All contacts",
+      sectionHidden,
+    };
+  });
+}
+
+const emptyContact: Contact = {
+  id: "",
+  firstName: "",
+  lastName: "",
+  company: "",
+  role: "",
+  email: "",
+  phone: "",
+  location: "",
+  handle: "",
+  website: "",
+  avatarUrl: "",
+  notes: "",
+  favorite: false,
+  createdAt: "",
+  updatedAt: "",
+};
+
+export function toContactView(contact: Contact | null): ContactView {
+  const value = contact ?? emptyContact;
+  const missing = contact === null;
+  const name = getContactName(value);
+
+  return {
+    ...value,
+    name,
+    summary: [value.role, value.company, value.location]
+      .filter(Boolean)
+      .join(" · "),
+    editHref: contact ? `/contacts/${value.id}/edit` : "/contacts",
+    initials: getContactInitials(value),
+    avatarStyle: getAvatarStyle(value.id),
+    avatarAlt: `${name} portrait`,
+    avatarHidden: !value.avatarUrl,
+    favoriteNextValue: value.favorite ? "false" : "true",
+    favoriteLabel: value.favorite
+      ? "Remove from favorites"
+      : "Add to favorites",
+    favoriteGlyph: value.favorite ? "★" : "☆",
+    websiteHidden: !value.website,
+    handleHidden: !value.handle,
+    emailLabel: value.email || "Not provided",
+    phoneLabel: value.phone || "Not provided",
+    notesLabel: value.notes || "No notes yet.",
+    hidden: missing,
+    missingHidden: !missing,
+  };
+}
