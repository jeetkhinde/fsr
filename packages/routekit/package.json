{
  "name": "@kiln/routekit",
  "version": "0.1.0",
  "description": "File-based router and layout engine for Kiln.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
