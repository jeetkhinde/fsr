    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kiln/core": "workspace:*",
    "@kiln/engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "vite": "^5.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
