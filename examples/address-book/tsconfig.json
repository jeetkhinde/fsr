{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": [
    "client/**/*",
    "components/**/*",
    "db/**/*",
    "features/**/*",
    "pages/**/*",
    "scripts/**/*",
    "src/**/*",
    "kiln.config.ts",
    "playwright.config.ts",
    "tests/**/*",
    "types/**/*"
  ]
}
