{
  "name": "@kiln-app/jags-list",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "tsc --noEmit",
    "db:migrate": "bun scripts/migrate.ts",
    "auth:migrate": "bunx @better-auth/cli@latest migrate -y",
    "bootstrap-superadmin": "bun scripts/bootstrap-superadmin.ts",
    "test": "bun test tests/smoke.test.ts db/validation.test.ts lib/roles.test.ts db/positions.test.ts",
    "test:db": "bun --env-file=.env test db/schema.integration.test.ts && bun --env-file=.env test lib/auth.integration.test.ts && bun --env-file=.env test db/invites.integration.test.ts && bun --env-file=.env test lib/activity.integration.test.ts && bun --env-file=.env test db/projects.integration.test.ts && bun --env-file=.env test db/tasks.integration.test.ts",
    "test:app": "RUN_APP_TESTS=1 bun --env-file=.env test tests/app.integration.test.ts",
    "test:purity": "RUN_APP_TESTS=1 bun --env-file=.env test tests/purity.integration.test.ts",
    "test:crud": "RUN_APP_TESTS=1 bun --env-file=.env test tests/crud.integration.test.ts"
  },
  "dependencies": {
    "@kiln/adapter-elysia": "workspace:*",
    "@kiln/core": "workspace:*",
    "@kiln/engine": "workspace:*",
    "@kiln/routekit": "workspace:*",
    "better-auth": "^1.6.23",
    "elysia": "^1.0.12",
    "pg": "^8.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.5"
  }
}
