DATABASE_URL=postgresql://localhost:5432/jagslist
# Use a dedicated Redis logical DB — Kiln cache keys (kiln:html:/, etc.) are
# not namespaced per app, so two Kiln apps sharing db 0 collide on shared
# routes like "/". Give each app its own db index.
REDIS_URL=redis://localhost:6379/3
PORT=3200
BETTER_AUTH_URL=http://localhost:3200
BETTER_AUTH_SECRET=generate-a-long-random-string
